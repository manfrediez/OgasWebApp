MONGODB_URI=mongodb://localhost:27017/pitu-app
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-min-32-chars
APP_PORT=3000
FRONTEND_URL=http://localhost:4200

# 64 hex characters (32 bytes) — used for AES-256-GCM encryption of Strava tokens
ENCRYPTION_KEY=your-64-hex-char-encryption-key-here

# Strava OAuth (optional — required only for Strava integration)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your-strava-webhook-verify-token

# Resend email service (optional — invites will show link in response if not set)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=OGAS <noreply@yourdomain.com>
